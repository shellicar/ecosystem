core-di
claude-cli
cosmos-query-builder
graphql-codegen-treeshake
svelte-adapter-azure-functions
ui-shadcn
winston-azure-application-insights"

# Config/meta repos (no npm package, simplified ruleset)
CONFIG_REPOS="ecosystem"

# GitHub owner
GITHUB_OWNER="shellicar"

# Workspace directory
WORKSPACE_DIR="/home/stephen/repos/@shellicar"

# App repos outside the workspace (absolute paths).
# Define APP_REPOS in .env at the ecosystem root to include additional repos.
APP_REPOS=""
if [ -f "$SCRIPT_DIR/../.env" ]; then
  . "$SCRIPT_DIR/../.env"
fi

# Resolve a repo name or absolute path to an absolute path
repo_path() {
  case "$1" in
    /*) printf '%s' "$1" ;;
    *)  printf '%s/%s' "$WORKSPACE_DIR" "$1" ;;
  esac
}

# Precomputed full-path lists (used by scripts that iterate all repos)
ALL_REPO_DIRS=""
for _r in $ALL_REPOS; do
  ALL_REPO_DIRS="${ALL_REPO_DIRS}${WORKSPACE_DIR}/${_r}
"
done
for _r in $APP_REPOS; do
  ALL_REPO_DIRS="${ALL_REPO_DIRS}${_r}
"
done

LIBRARY_REPO_DIRS=""
for _r in $LIBRARY_REPOS; do
  LIBRARY_REPO_DIRS="${LIBRARY_REPO_DIRS}${WORKSPACE_DIR}/${_r}
"
done
