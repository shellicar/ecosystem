{
  "name": "@shellicar/build-azure-local-settings",
  "private": false,
  "version": "1.0.1",
  "type": "module",
  "license": "MIT",
  "author": "Stephen Hellicar",
  "description": "Build plugin that loads Azure local.settings.json with Key Vault reference resolution for non-Azure-Functions apps.",
  "keywords": [
    "esbuild",
    "tsup",
    "azure",
    "local-settings",
    "key-vault",
    "azure-functions",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shellicar/ecosystem.git",
    "directory": "packages/build-azure-local-settings"
  },
  "bugs": {
    "url": "https://github.com/shellicar/ecosystem/issues?q=is%3Aissue%20state%3Aopen%20label%3A%22pkg%3A%20build-azure-local-settings%22"
  },
  "homepage": "https://github.com/shellicar/ecosystem/tree/main/packages/build-azure-local-settings#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esm/esbuild.d.ts",
        "default": "./dist/esm/esbuild.js"
      },
      "require": {
        "types": "./dist/cjs/esbuild.d.cts",
        "default": "./dist/cjs/esbuild.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/esm/runtime.d.ts",
        "default": "./dist/esm/runtime.js"
      },
      "require": {
        "types": "./dist/cjs/runtime.d.cts",
        "default": "./dist/cjs/runtime.cjs"
      }
    },
    "./cjs-shim": {
      "import": {
        "default": "./dist/esm/cjs-shim.js"
      }
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "index": [
        "./dist/esm/index.d.ts"
      ],
      "esbuild": [
        "./dist/esm/esbuild.d.ts"
      ],
      "runtime": [
        "./dist/esm/runtime.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "*.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.check.json",
    "watch": "tsup --watch"
  },
  "peerDependencies": {
    "esbuild": "^0.27"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.11.1",
    "regexp.escape": "^2.0.1"
  },
  "devDependencies": {
    "@shellicar/typescript-config": "workspace:^",
    "@types/node": "^25.6.0",
    "@types/regexp.escape": "^2.0.0",
    "esbuild": "^0.27.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
