{
  "name": "@shellicar/build-clean",
  "private": false,
  "version": "1.3.2",
  "type": "module",
  "license": "MIT",
  "author": "Stephen Hellicar",
  "description": "Build plugin that automatically cleans unused files from output directories.",
  "keywords": [
    "esbuild",
    "tsup",
    "build",
    "clean",
    "plugin",
    "unplugin",
    "rolldown"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shellicar/ecosystem.git",
    "directory": "packages/build-clean"
  },
  "bugs": {
    "url": "https://github.com/shellicar/ecosystem/issues?q=is%3Aissue%20state%3Aopen%20label%3A%22pkg%3A%20build-clean%22"
  },
  "homepage": "https://github.com/shellicar/ecosystem/tree/main/packages/build-clean#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./astro": {
      "import": {
        "types": "./dist/esm/astro.d.ts",
        "default": "./dist/esm/astro.js"
      },
      "require": {
        "types": "./dist/cjs/astro.d.cts",
        "default": "./dist/cjs/astro.cjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esm/esbuild.d.ts",
        "default": "./dist/esm/esbuild.js"
      },
      "require": {
        "types": "./dist/cjs/esbuild.d.cts",
        "default": "./dist/cjs/esbuild.cjs"
      }
    },
    "./farm": {
      "import": {
        "types": "./dist/esm/farm.d.ts",
        "default": "./dist/esm/farm.js"
      },
      "require": {
        "types": "./dist/cjs/farm.d.cts",
        "default": "./dist/cjs/farm.cjs"
      }
    },
    "./nuxt": {
      "import": {
        "types": "./dist/esm/nuxt.d.ts",
        "default": "./dist/esm/nuxt.js"
      },
      "require": {
        "types": "./dist/cjs/nuxt.d.cts",
        "default": "./dist/cjs/nuxt.cjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/esm/rollup.d.ts",
        "default": "./dist/esm/rollup.js"
      },
      "require": {
        "types": "./dist/cjs/rollup.d.cts",
        "default": "./dist/cjs/rollup.cjs"
      }
    },
    "./rspack": {
      "import": {
        "types": "./dist/esm/rspack.d.ts",
        "default": "./dist/esm/rspack.js"
      },
      "require": {
        "types": "./dist/cjs/rspack.d.cts",
        "default": "./dist/cjs/rspack.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/esm/types.d.ts",
        "default": "./dist/esm/types.js"
      },
      "require": {
        "types": "./dist/cjs/types.d.cts",
        "default": "./dist/cjs/types.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/esm/vite.d.ts",
        "default": "./dist/esm/vite.js"
      },
      "require": {
        "types": "./dist/cjs/vite.d.cts",
        "default": "./dist/cjs/vite.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/esm/webpack.d.ts",
        "default": "./dist/esm/webpack.js"
      },
      "require": {
        "types": "./dist/cjs/webpack.d.cts",
        "default": "./dist/cjs/webpack.cjs"
      }
    },
    "./rolldown": {
      "import": {
        "types": "./dist/esm/rolldown.d.ts",
        "default": "./dist/esm/rolldown.js"
      },
      "require": {
        "types": "./dist/cjs/rolldown.d.cts",
        "default": "./dist/cjs/rolldown.cjs"
      }
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "index": [
        "./dist/esm/index.d.ts"
      ],
      "astro": [
        "./dist/esm/astro.d.ts"
      ],
      "esbuild": [
        "./dist/esm/esbuild.d.ts"
      ],
      "farm": [
        "./dist/esm/farm.d.ts"
      ],
      "nuxt": [
        "./dist/esm/nuxt.d.ts"
      ],
      "rollup": [
        "./dist/esm/rollup.d.ts"
      ],
      "rspack": [
        "./dist/esm/rspack.d.ts"
      ],
      "types": [
        "./dist/esm/types.d.ts"
      ],
      "vite": [
        "./dist/esm/vite.d.ts"
      ],
      "webpack": [
        "./dist/esm/webpack.d.ts"
      ],
      "rolldown": [
        "./dist/esm/rolldown.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "*.md"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc -p tsconfig.check.json",
    "watch": "tsup --watch"
  },
  "peerDependencies": {
    "@farmfe/core": ">=1",
    "@nuxt/kit": "^3",
    "@nuxt/schema": "^3",
    "esbuild": "^0.27",
    "rolldown": ">=1.0.0-rc.1",
    "rollup": "^3",
    "vite": "^6",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@farmfe/core": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    },
    "@nuxt/schema": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^3.21.2",
    "@shellicar/typescript-config": "workspace:^",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.6.0",
    "esbuild": "^0.27.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "unplugin": "^2.3.11"
  }
}
