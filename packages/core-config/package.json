{
  "name": "@shellicar/core-config",
  "private": false,
  "version": "2.1.4",
  "type": "module",
  "license": "MIT",
  "author": "Stephen Hellicar",
  "description": "A library for securely handling sensitive configuration values like connection strings, URLs, and secrets.",
  "keywords": [
    "secure",
    "connection",
    "string",
    "connection string",
    "config",
    "secret",
    "URL"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shellicar/ecosystem.git",
    "directory": "packages/core-config"
  },
  "bugs": {
    "url": "https://github.com/shellicar/ecosystem/issues?q=is%3Aissue%20state%3Aopen%20label%3A%22pkg%3A%20core-config%22"
  },
  "homepage": "https://github.com/shellicar/ecosystem/tree/main/packages/core-config#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "typesVersions": {
    "*": {
      "index": [
        "./dist/esm/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "*.md"
  ],
  "scripts": {
    "build": "tsup-node",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.check.json",
    "watch": "tsup-node --watch"
  },
  "devDependencies": {
    "@shellicar/typescript-config": "workspace:*",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.6.0",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
