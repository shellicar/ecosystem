{
  "name": "@shellicar/core-di-engine",
  "private": false,
  "version": "5.0.0-alpha.1",
  "type": "module",
  "license": "MIT",
  "author": "Stephen Hellicar",
  "description": "The shared engine core-di and core-di-lite compose from",
  "keywords": [
    "dependency injection",
    "di",
    "inversion of control container",
    "ioc"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shellicar/ecosystem.git",
    "directory": "packages/core-di-engine"
  },
  "bugs": {
    "url": "https://github.com/shellicar/ecosystem/issues"
  },
  "homepage": "https://github.com/shellicar/ecosystem/tree/main/packages/core-di-engine#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      },
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./dependsOn": {
      "require": {
        "types": "./dist/cjs/dependsOn.d.cts",
        "default": "./dist/cjs/dependsOn.cjs"
      },
      "import": {
        "types": "./dist/esm/dependsOn.d.ts",
        "default": "./dist/esm/dependsOn.js"
      }
    },
    "./polyfill": {
      "require": {
        "types": "./dist/cjs/polyfill.d.cts",
        "default": "./dist/cjs/polyfill.cjs"
      },
      "import": {
        "types": "./dist/esm/polyfill.d.ts",
        "default": "./dist/esm/polyfill.js"
      }
    }
  },
  "sideEffects": [
    "./dist/esm/index.js",
    "./dist/cjs/index.cjs",
    "**/polyfill.*"
  ],
  "files": [
    "dist",
    "*.md"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc -p tsconfig.check.json",
    "watch": "tsup --watch"
  },
  "devDependencies": {
    "@shellicar/typescript-config": "workspace:^",
    "@types/node": "^25.8.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
