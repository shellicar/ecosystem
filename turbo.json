{
  "$schema": "node_modules/turbo/schema.json",
  "ui": "stream-with-experimental-timestamps",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["tsconfig.json", "src/**/*.ts", "tsup.config.ts"],
      "outputs": ["dist"],
      "outputLogs": "new-only"
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["**/*.ts", "tsconfig.json", "tsconfig.check.json"],
      "outputs": ["node_modules/.cache/tsbuildinfo.json"],
      "outputLogs": "errors-only"
    }
  }
}
